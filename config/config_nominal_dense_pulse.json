{
  "data": {
    "tbit": 3.125e-11,
    "n_bits": 8500,
    "samples_per_bit": 512,
    "prbs_seed": 90,
    "waveform": {
      "vpp": 1,
      "vcm": 0.0
    }
  },
  "input_waveform": {
    "model": "pulse_response_dense",
    "file": "./pulse_response/pulse_response_dense_interp_8_isi.csv"
  },
  "tx_eq": {
    "enabled": true,
    "model": "fir_3tap",
    "fir_3tap": {
      "c_pre": -0.0,
      "c_main": 0.80,
      "c_post":-0.2 
    },
    "fir_3tap_causal": {
      "c_main": 0.8,
      "c_post1": -0.15,
      "c_post2": -0.0
    }
  },
  "channel": {
    "enabled": false,
    "model": "fir_ui",
    "fir_ui": {
      "taps": [
        0.2613,
        0.4774,
        0.2613
      ]
    },
    "one_pole": {
      "fp_hz": 15000000000.0,
      "gain": 1.0
    }
  },
  "frontend": {
    "enabled": true,
    "model": "one_pole",
    "one_pole": {
      "fp_hz": 64e9,
      "gain": 1.0
    },
    "measured_tf": {
      "enabled": false,
      "file": "",
      "format": "csv",
      "freq_column": "freq_hz",
      "real_column": "h_real",
      "imag_column": "h_imag"
    }
  },
  "sampling": {
    "sigma_j": 500e-15,
    "n_phases": 32,
    "n_ui_collect": 1024,
    "skip_initial_ui": 10
  },
  "nonlinearity": {
    "enabled": true,
    "model": "polynomial",
    "polynomial": {
      "a1": 0.5,
      "a2": 0.2,
      "a3": -0.4
    }
  },
  "noise": {
    "enabled": true,
    "sigma_v": 0.001
  },
  "adc": {
  "enabled": true,
  "n_bits": 6,
  "vmin": -0.4,
  "vmax": 0.4
  },
  "eye_metrics": {
    "k_sigma": 3,
    "eye_width": {
      "mode": "safe_positive",
      "value": 0.0
    }
  },
  "output": {
    "enabled": true,
    "show_plots": true,
    "save_plots": false,
    "save_prefix": "eye_monitor_v1",
    "waveform_plot": {
      "ui_start": 2.0,
      "ui_stop": 50.0
    }
  },
  "debug": {
    "plot_nl_error": true,
    "plot_frequency_response": true,
    "frequency_plot_points": 1000
  }
}
